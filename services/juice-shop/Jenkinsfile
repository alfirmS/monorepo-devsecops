// ================================================================
// Jenkinsfile — juice-shop [DEV]
// Auto-generated by Jenkins Service Generator
// ================================================================

pipeline {

  parameters {
    string(
      name: 'GIT_BRANCH',
      defaultValue: 'dev',
      description: 'Branch atau tag yang akan di-build'
    )
  }

  environment {
    // ── Service & ENV ────────────────────────────────────────
    SERVICE             = 'juice-shop'
    ENV                 = 'dev'

    // ── Repositories ─────────────────────────────────────────
    SERVICE_REPO        = 'git@github.com:alfirmS/juice-shop.git'

    // ── Helm ─────────────────────────────────────────────────
    HELM_CHART_PATH     = 'services/juice-shop/helm-juice-shop'
    HELM_VALUES_PATH    = 'services/juice-shop/helm-juice-shop/values.yaml'
    KUBE_NAMESPACE      = 'dev'

    // ── Credentials ──────────────────────────────────────────
    REGISTRY_HOST       = 'index.docker.io/sfirman87'
    REGISTRY_CRED_ID    = 'dockerhub-credentials'
    KUBECONFIG_CRED_ID  = 'kubeconfig-dev'
    DOCKERHUB_OCI_CRED  = 'dockerhub-oci-credentials'
    GIT_CRED_ID         = 'git-credential-id'
  }

  agent any

  stages {

    // ── 1. Checkout Service Repo ─────────────────────────────
    stage('Checkout') {
      steps {
        // Monorepo sudah di-checkout otomatis oleh Jenkins (untuk baca Jenkinsfile ini)
        // Checkout service repo ke subfolder service-src
        checkout([
          $class: 'GitSCM',
          branches: [[name: "${params.GIT_BRANCH}"]],
          extensions: [[$class: 'RelativeTargetDirectory', relativeTargetDir: 'service-src']],
          userRemoteConfigs: [[
            url: "${SERVICE_REPO}",
            credentialsId: "${GIT_CRED_ID}"
          ]]
        ])
      }
    }

    // ── 2. Build & Push Docker Image ─────────────────────────
    stage('Build & Push Docker Image') {
      steps {
        script {
          def commitId  = sh(script: 'git -C service-src rev-parse --short HEAD', returnStdout: true).trim()
          def dateStamp = sh(script: 'date +%d%m%y', returnStdout: true).trim()
          env.IMAGE_TAG = "${commitId}-${dateStamp}-${BUILD_NUMBER}"

          withCredentials([usernamePassword(
            credentialsId: env.REGISTRY_CRED_ID,
            usernameVariable: 'REG_USER',
            passwordVariable: 'REG_PASS'
          )]) {
            sh """
              docker login -u "${REG_USER}" -p "${REG_PASS}" ${REGISTRY_HOST}

              docker build \
                -f service-src/Dockerfile \
                -t ${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG} \
                service-src/

              docker push ${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG}
              docker rmi ${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG} || true
            """
          }
          echo "✅ Image pushed: ${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG}"
        }
      }
    }

    // ── 3. Prepare Helm ──────────────────────────────────────
    stage('Prepare Helm') {
      steps {
        script {
          withCredentials([usernamePassword(
            credentialsId: env.DOCKERHUB_OCI_CRED,
            usernameVariable: 'DH_USER',
            passwordVariable: 'DH_PASS'
          )]) {
            sh """
              helm registry login registry-1.docker.io -u "${DH_USER}" -p "${DH_PASS}"
              helm dep update ${HELM_CHART_PATH}
              helm registry logout registry-1.docker.io
            """
          }

          // Set version & appVersion di Chart.yaml mengikuti IMAGE_TAG
          sh """
            sed -i "s/^version:.*/version: ${IMAGE_TAG}/" ${HELM_CHART_PATH}/Chart.yaml
            sed -i "s/^appVersion:.*/appVersion: \\"${IMAGE_TAG}\\"/" ${HELM_CHART_PATH}/Chart.yaml
          """
          echo "✅ Helm siap dari monorepo"
        }
      }
    }

    // ── 4. Deploy ────────────────────────────────────────────
    stage('Deploy') {
      steps {
        script {
          withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {

            sh """
              helm lint ${HELM_CHART_PATH} \
                -f ${HELM_VALUES_PATH} \
                --set image.tag=${IMAGE_TAG}

              helm upgrade --install ${SERVICE} ${HELM_CHART_PATH} \
                -f ${HELM_VALUES_PATH} \
                --set image.tag=${IMAGE_TAG} \
                --namespace ${KUBE_NAMESPACE} \
                --dry-run --debug
            """
            echo "✅ Helm lint & dry-run OK"

            sh """
              helm upgrade --install ${SERVICE} ${HELM_CHART_PATH} \
                -f ${HELM_VALUES_PATH} \
                --set image.tag=${IMAGE_TAG} \
                --namespace ${KUBE_NAMESPACE} \
                --create-namespace \
                --atomic \
                --timeout 5m \
                --history-max 5
            """
            echo "✅ Helm deploy selesai"
          }
        }
      }
    }

    // ── 5. Post-Deploy Check ─────────────────────────────────
    stage('Post-Deploy Check') {
      steps {
        script {
          withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
            sh """
              echo "─── Rollout Status ───"
              kubectl rollout status deployment/${SERVICE} \
                -n ${KUBE_NAMESPACE} --timeout=3m

              echo "─── Pods ───"
              kubectl get pods -n ${KUBE_NAMESPACE} -l app.kubernetes.io/name=${SERVICE} -o wide

              echo "─── Recent Events ───"
              kubectl get events -n ${KUBE_NAMESPACE} \
                --field-selector involvedObject.name=${SERVICE} \
                --sort-by='.lastTimestamp' | tail -10
            """
          }
          echo "✅ Post-deploy check OK"
        }
      }
    }
  }

  post {
    success {
      echo """
✅ Deploy ${SERVICE} ke [DEV] berhasil!
   Image tag : ${IMAGE_TAG}
   Namespace : ${KUBE_NAMESPACE}
      """
    }
    failure {
      script {
        echo "❌ Deploy gagal, mencoba rollback..."
        withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
          sh """
            helm rollback ${SERVICE} 0 -n ${KUBE_NAMESPACE} || true
          """
        }
      }
    }
    cleanup {
      sh 'rm -rf service-src || true'
    }
  }
}
