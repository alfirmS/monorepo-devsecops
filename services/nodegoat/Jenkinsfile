pipeline {



  environment {
    // ── Service & ENV ────────────────────────────────────────
    SERVICE             = 'nodegoat'
    ENV                 = 'dev'

    // ── Repositories ─────────────────────────────────────────
    SERVICE_REPO        = 'git@github.com:alfirmS/nodegoat.git'

    // ── Helm ─────────────────────────────────────────────────
    HELM_CHART_PATH     = 'services/nodegoat/helm-nodegoat'
    HELM_VALUES_PATH    = 'services/nodegoat/helm-nodegoat/values.yaml'
    KUBE_NAMESPACE      = 'dev'

    // ── Credentials ──────────────────────────────────────────
    REGISTRY_HOST       = 'index.docker.io/sfirman87'
    REGISTRY_CRED_ID    = 'dockerhub-credential-id'
    KUBECONFIG_CRED_ID  = 'kubeconfig-dev'
    DOCKERHUB_OCI_CRED  = 'dockerhub-credential-id'
    GIT_CRED_ID         = 'git-credential-id'
  }

  // ════════════════════════════════════════════════════════════
  //  KUBERNETES AGENT
  //
  //  Pod layout:
  //  ┌──────────────────────────────────────────────────────────┐
  //  │  jnlp    ← auto-inject plugin, defaultContainer         │
  //  │           ← checkout, script logic, readFile/writeFile   │
  //  │                                                          │
  //  │  kaniko  ← build & push Docker image (tanpa Docker daemon)│
  //  │           ← command: [/busybox/cat] + tty               │
  //  │           ← volume: harbor-regcred → /kaniko/.docker    │
  //  │                                                          │
  //  │  helm    ← helm dep update, helm upgrade, helm rollback  │
  //  │           ← juga ada kubectl untuk post-deploy check     │
  //  │           ← command: [cat] + tty                        │
  //  └──────────────────────────────────────────────────────────┘
  //
  //  Kenapa kaniko, bukan docker?
  //    Pipeline jalan di Kubernetes pod — tidak ada Docker daemon.
  //    Kaniko build image langsung dari Dockerfile tanpa daemon,
  //    push langsung ke registry via /kaniko/.docker/config.json.
  //
  //  Secret harbor-regcred:
  //    kubectl create secret docker-registry harbor-regcred \
  //      --docker-server=index.docker.io/sfirman87 \
  //      --docker-username=robot$jenkins \
  //      --docker-password=<token> \
  //      --namespace=dev
  //
  //  Secret harus ada di DUA namespace:
  //    - namespace jenkins  → untuk pull image kaniko/helm saat pod dibuat
  //    - namespace dev → untuk pull image service saat deploy
  // ════════════════════════════════════════════════════════════
  agent {
    kubernetes {
      cloud            'k3d'   // ganti ke 'k3d' jika nama cloud kamu k3d
      defaultContainer 'jnlp'        // checkout + script logic default di sini
      yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: ci
    service: nodegoat
    env: dev
spec:
  securityContext:
    runAsUser: 0
    runAsGroup: 0

  imagePullSecrets:
    - name: harbor-regcred

  containers:

    # ── kaniko: build & push image ─────────────────────────
    # Tidak butuh Docker daemon — aman di dalam Kubernetes pod.
    # config.json di-mount dari secret harbor-regcred sebagai
    # projected volume supaya kaniko bisa push ke registry.
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      imagePullPolicy: IfNotPresent
      command:
        - /busybox/cat
      tty: true
      env:
        - name: GODEBUG
          value: "http2client=0"
      volumeMounts:
        - name: harbor-regcred
          mountPath: /kaniko/.docker
      resources:
        requests:
          cpu: "500m"
          memory: "1Gi"
        limits:
          cpu: "1"
          memory: "2Gi"

    # ── helm: helm + kubectl ────────────────────────────────
    # Dipakai untuk: helm dep update, helm lint, helm upgrade,
    # helm rollback, kubectl rollout status, kubectl get pods.
    - name: helm
      image: alpine/helm:latest
      imagePullPolicy: IfNotPresent
      command:
        - cat
      tty: true
      resources:
        requests:
          cpu: "200m"
          memory: "256Mi"
        limits:
          cpu: "500m"
          memory: "512Mi"

  volumes:
    # Projected secret → config.json untuk kaniko push/pull
    # Key .dockerconfigjson dari secret harbor-regcred
    # di-project ke path config.json di /kaniko/.docker/
    - name: regcred
      projected:
        sources:
          - secret:
              name: regcred
              items:
                - key: .dockerconfigjson
                  path: config.json
"""
    }
  }

  triggers {
    githubPush()
  }


  stages {

    // ── 1. Checkout Service Repo ─────────────────────────────
    // GitSCM checkout → jalan di jnlp (defaultContainer)
    // Plugin GitSCM tidak butuh container khusus
    stage('Checkout') {
      steps {
        // Monorepo sudah di-checkout otomatis oleh Jenkins (untuk baca Jenkinsfile ini)
        // Checkout service repo ke subfolder service-src
        checkout([
          $class: 'GitSCM',
          branches: [[name: "master"]],
          extensions: [[$class: 'RelativeTargetDirectory', relativeTargetDir: 'service-src']],
          userRemoteConfigs: [[
            url: "${SERVICE_REPO}",
            credentialsId: "${GIT_CRED_ID}"
          ]]
        ])
      }
    }

    // ── 2. Build & Push Docker Image ─────────────────────────
    // docker login + docker build + docker push
    // → diganti kaniko executor (tidak butuh Docker daemon)
    // → container('kaniko') eksplisit karena butuh /busybox/sh
    stage('Build & Push Image') {
      steps {
        container('kaniko') {
          script {
            def commitId  = sh(script: 'git -C service-src rev-parse --short HEAD', returnStdout: true).trim()
            def dateStamp = sh(script: 'date +%d%m%y', returnStdout: true).trim()
            env.IMAGE_TAG = "${commitId}.${dateStamp}.${BUILD_NUMBER}"

            // Kaniko membaca kredensial registry dari /kaniko/.docker/config.json
            // yang sudah di-mount dari secret harbor-regcred via projected volume.
            // Tidak perlu docker login manual.
            sh """
              /kaniko/executor \
                --context=dir://service-src \
                --dockerfile=service-src/Dockerfile \
                --destination=${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG} \
                --cache=true \
                --cache-ttl=24h \
                --compressed-caching=false \
                --snapshot-mode=redo
            """
            echo "Image pushed: ${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG}"
          }
        }
      }
    }

    // ── 3. Prepare Helm ──────────────────────────────────────
    // helm registry login + helm dep update + sed Chart.yaml
    // → container('helm') karena butuh helm binary
    stage('Prepare Helm') {
      steps {
        container('helm') {
          script {
            // Install kubectl jika belum ada di image alpine/helm
            sh 'apk add --no-cache curl kubectl 2>/dev/null || true'

            def dateStamp = sh(script: 'date +%d%m%y', returnStdout: true).trim()
            env.CHART_VERSION = "${dateStamp}.${BUILD_NUMBER}"

            withCredentials([usernamePassword(
              credentialsId: env.DOCKERHUB_OCI_CRED,
              usernameVariable: 'DH_USER',
              passwordVariable: 'DH_PASS'
            )]) {
              sh """
                helm registry login registry-1.docker.io -u "${DH_USER}" -p "${DH_PASS}"
                helm dep update ${HELM_CHART_PATH}
                helm registry logout registry-1.docker.io
              """
            }

            sh """
              sed -i "s|^version:.*|version: \\"${CHART_VERSION}\\"|" ${HELM_CHART_PATH}/Chart.yaml
              sed -i "s|^appVersion:.*|appVersion: \\"${IMAGE_TAG}\\"|" ${HELM_CHART_PATH}/Chart.yaml
            """
            echo "Helm chart siap — version: ${CHART_VERSION}, appVersion: ${IMAGE_TAG}"
          }
        }
      }
    }

    // ── 4. Deploy ────────────────────────────────────────────
    // helm lint + helm upgrade --install
    // → container('helm')
    // kubeconfig di-inject via withCredentials file credential
    stage('Deploy') {
      steps {
        container('helm') {
          script {
            withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {

              sh """
                helm lint ${HELM_CHART_PATH} \
                  -f ${HELM_VALUES_PATH} \
                  --set image.repository=${REGISTRY_HOST}/${SERVICE} \
                  --set image.tag=${IMAGE_TAG}

                helm upgrade --install ${SERVICE} ${HELM_CHART_PATH} \
                  -f ${HELM_VALUES_PATH} \
                  --set image.repository=${REGISTRY_HOST}/${SERVICE} \
                  --set image.tag=${IMAGE_TAG} \
                  --namespace ${KUBE_NAMESPACE} \
                  --dry-run --debug
              """
              echo "Helm lint & dry-run OK"

              sh """
                helm upgrade --install ${SERVICE} ${HELM_CHART_PATH} \
                  -f ${HELM_VALUES_PATH} \
                  --set image.repository=${REGISTRY_HOST}/${SERVICE} \
                  --set image.tag=${IMAGE_TAG} \
                  --namespace ${KUBE_NAMESPACE} \
                  --create-namespace \
                  --atomic \
                  --timeout 5m \
                  --history-max 5
              """
              echo "Helm deploy selesai"
            }
          }
        }
      }
    }

    // ── 5. Post-Deploy Check ─────────────────────────────────
    // kubectl rollout status + kubectl get pods + kubectl get events
    // → container('helm') — kubectl sudah di-install di stage Prepare Helm
    stage('Post-Deploy Check') {
      steps {
        container('helm') {
          script {
            withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
              sh """
                echo "─── Rollout Status ───"
                kubectl rollout status deployment/${SERVICE} \
                  -n ${KUBE_NAMESPACE} --timeout=3m

                echo "─── Pods ───"
                kubectl get pods -n ${KUBE_NAMESPACE} -l app.kubernetes.io/name=${SERVICE} -o wide

                echo "─── Recent Events ───"
                kubectl get events -n ${KUBE_NAMESPACE} \
                  --field-selector involvedObject.name=${SERVICE} \
                  --sort-by='.lastTimestamp' | tail -10
              """
            }
            echo "Post-deploy check OK"
          }
        }
      }
    }
  }

  post {
    success {
      echo """
Deploy ${SERVICE} ke [DEV] berhasil!
   Image tag : ${IMAGE_TAG}
   Namespace : ${KUBE_NAMESPACE}
      """
    }
    failure {
      container('helm') {
        script {
          echo "Deploy gagal, mencoba rollback..."
          withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
            sh """
              helm rollback ${SERVICE} 0 -n ${KUBE_NAMESPACE} || true
            """
          }
        }
      }
    }
    cleanup {
      sh 'rm -rf service-src || true'
    }
  }
}
