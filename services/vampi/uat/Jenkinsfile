pipeline {



  environment {
    // ── Service & ENV ────────────────────────────────────────
    SERVICE             = 'vampi'
    ENV                 = 'uat'

    // ── Repositories ─────────────────────────────────────────
    SERVICE_REPO        = 'git@github.com:alfirmS/vampi.git'

    // ── Helm ─────────────────────────────────────────────────
    // Path per-env: setiap environment punya direktori sendiri
    HELM_CHART_PATH     = 'services/vampi/uat/helm-vampi'
    HELM_VALUES_PATH    = 'services/vampi/uat/helm-vampi/values.yaml'
    KUBE_NAMESPACE      = 'uat'

    // ── Credentials ──────────────────────────────────────────
    REGISTRY_HOST       = '192.168.100.41:9443/lab'
    REGISTRY_CRED_ID    = 'harbor-credential-id'
    KUBECONFIG_CRED_ID  = 'kubeconfig-credential-id'
    DOCKERHUB_OCI_CRED  = 'harbor-credential-id'
    GIT_CRED_ID         = 'git-credential-id'
  }

  // ════════════════════════════════════════════════════════════
  //  KUBERNETES AGENT
  //
  //  Pod layout:
  //  ┌──────────────────────────────────────────────────────────┐
  //  │  jnlp    ← auto-inject plugin, defaultContainer         │
  //  │           ← checkout, script logic, readFile/writeFile   │
  //  │                                                          │
  //  │  kaniko  ← build & push Docker image (tanpa Docker daemon)│
  //  │           ← command: [/busybox/cat] + tty               │
  //  │           ← volume: regcred → /kaniko/.docker    │
  //  │                                                          │
  //  │  helm    ← helm dep update, helm upgrade, helm rollback  │
  //  │           ← juga ada kubectl untuk post-deploy check     │
  //  │           ← command: [cat] + tty                        │
  //  └──────────────────────────────────────────────────────────┘
  //
  //  Kenapa kaniko, bukan docker?
  //    Pipeline jalan di Kubernetes pod — tidak ada Docker daemon.
  //    Kaniko build image langsung dari Dockerfile tanpa daemon,
  //    push langsung ke registry via /kaniko/.docker/config.json.
  //
  //  Secret regcred:
  //    kubectl create secret docker-registry regcred \
  //      --docker-server=192.168.100.41:9443 \
  //      --docker-username=robot$jenkins \
  //      --docker-password=<token> \
  //      --namespace=uat
  //
  //  Secret harus ada di DUA namespace:
  //    - namespace jenkins  → untuk pull image kaniko/helm saat pod dibuat
  //    - namespace uat → untuk pull image service saat deploy
  // ════════════════════════════════════════════════════════════
  agent {
    kubernetes {
      cloud            'k3d'   // ganti ke 'k3d' jika nama cloud kamu k3d
      defaultContainer 'jnlp'        // checkout + script logic default di sini
      yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: ci
    service: vampi
    env: uat
spec:
  securityContext:
    runAsUser: 0
    runAsGroup: 0

  # REGISTRY_SECRET = nama Kubernetes secret type docker-registry
  # yang ada di namespace jenkins. Cek: kubectl get secret -n jenkins
  imagePullSecrets:
    - name: regcred

  containers:

    # ── kaniko: build & push image ─────────────────────────
    # Tidak butuh Docker daemon — aman di dalam Kubernetes pod.
    # config.json di-mount dari secret regcred sebagai
    # projected volume supaya kaniko bisa push ke registry.
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      imagePullPolicy: IfNotPresent
      command:
        - /busybox/cat
      tty: true
      env:
        - name: GODEBUG
          value: "http2client=0"
      volumeMounts:
        - name: registry-creds
          mountPath: /kaniko/.docker
      resources:
        requests:
          cpu: "500m"
          memory: "1Gi"
        limits:
          cpu: "1"
          memory: "2Gi"

    # ── helm: helm + kubectl ────────────────────────────────
    # Dipakai untuk: helm dep update, helm lint, helm upgrade,
    # helm rollback, kubectl rollout status, kubectl get pods.
    - name: helm
      image: alpine/helm:latest
      imagePullPolicy: IfNotPresent
      command:
        - cat
      tty: true
      resources:
        requests:
          cpu: "200m"
          memory: "256Mi"
        limits:
          cpu: "500m"
          memory: "512Mi"

  volumes:
    # Projected secret → config.json untuk kaniko push/pull
    # Key .dockerconfigjson dari secret regcred
    # di-project ke path config.json di /kaniko/.docker/
    - name: registry-creds
      projected:
        sources:
          - secret:
              name: regcred
              items:
                - key: .dockerconfigjson
                  path: config.json
"""
    }
  }

  triggers {
    githubPush()
  }


  stages {

    // ── 1. Checkout Service Repo ─────────────────────────────
    // GitSCM checkout → jalan di jnlp (defaultContainer)
    // Pakai dir() step (RelativeTargetDirectory deprecated di Pipeline)
    stage('Checkout') {
      steps {
        dir('service-src') {
          checkout([
            $class: 'GitSCM',
            branches: [[name: "master"]],
            userRemoteConfigs: [[
              url: "${SERVICE_REPO}",
              credentialsId: "${GIT_CRED_ID}"
            ]]
          ])
        }
      }
    }

    // ── 2. Build & Push Image ────────────────────────────────
    // PENTING: kaniko:debug hanya punya /busybox — tidak ada git, date, dsb.
    // Solusi: ambil commitId dan dateStamp di jnlp (defaultContainer) dulu,
    // simpan ke env, baru masuk container('kaniko') hanya untuk executor.
    stage('Build & Push Image') {
      steps {
        script {
          // ── Jalankan di jnlp (defaultContainer) ──
          // jnlp punya git (dari inbound-agent base image)
          def commitId  = sh(script: 'git -C service-src rev-parse --short HEAD', returnStdout: true).trim()
          def dateStamp = sh(script: 'date +%d%m%y', returnStdout: true).trim()
          env.IMAGE_TAG = "${commitId}.${dateStamp}.${BUILD_NUMBER}"
          echo "IMAGE_TAG: ${env.IMAGE_TAG}"
        }

        container('kaniko') {
          // ── Jalankan di kaniko ──
          // env.IMAGE_TAG sudah di-set di step sebelumnya, tersedia di semua container
          // Kaniko membaca /kaniko/.docker/config.json dari projected volume regcred
          sh """
            /kaniko/executor \
              --context=dir://\${WORKSPACE}/service-src \
              --dockerfile=\${WORKSPACE}/service-src/Dockerfile \
              --destination=${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG} \
	      --skip-tls-verify \
              --cache=true \
              --cache-ttl=24h \
              --compressed-caching=false \
              --snapshot-mode=redo
          """
          echo "Image pushed: ${REGISTRY_HOST}/${SERVICE}:${IMAGE_TAG}"
        }
      }
    }

    // ── 3. Prepare Helm ──────────────────────────────────────
    // helm registry login + helm dep update + sed Chart.yaml
    // → container('helm') karena butuh helm binary
    stage('Prepare Helm') {
      steps {
        container('helm') {
          script {
            // Install kubectl jika belum ada di image alpine/helm
            sh 'apk add --no-cache curl kubectl 2>/dev/null || true'

            def dateStamp = sh(script: 'date +%d%m%y', returnStdout: true).trim()
            env.CHART_VERSION = "${dateStamp}.${BUILD_NUMBER}"

            withCredentials([usernamePassword(
              credentialsId: env.DOCKERHUB_OCI_CRED,
              usernameVariable: 'DH_USER',
              passwordVariable: 'DH_PASS'
            )]) {
              sh """
                helm registry login registry-1.docker.io -u "${DH_USER}" -p "${DH_PASS}"
                helm dep update ${HELM_CHART_PATH}
                helm registry logout registry-1.docker.io
              """
            }

            sh """
              sed -i "s|^version:.*|version: \\"${CHART_VERSION}\\"|" ${HELM_CHART_PATH}/Chart.yaml
              sed -i "s|^appVersion:.*|appVersion: \\"${IMAGE_TAG}\\"|" ${HELM_CHART_PATH}/Chart.yaml
            """
            echo "Helm chart siap — version: ${CHART_VERSION}, appVersion: ${IMAGE_TAG}"
          }
        }
      }
    }

    // ── 4. Deploy ────────────────────────────────────────────
    // helm lint + helm upgrade --install
    // → container('helm')
    //
    // KUBECONFIG k3d issue:
    //   Kubeconfig yang di-generate k3d berisi server: https://0.0.0.0:<port>
    //   Address ini hanya valid dari host machine, tidak dari dalam pod.
    //   Fix: patch server URL ke kubernetes.default.svc:443 (internal cluster DNS)
    //   sebelum dipakai helm/kubectl.
    stage('Deploy') {
      steps {
        container('helm') {
          script {
            withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
                sh """
                  helm lint ${HELM_CHART_PATH} \
                    -f ${HELM_VALUES_PATH} \
                    --set image.repository=${REGISTRY_HOST}/${SERVICE} \
                    --set image.tag=${IMAGE_TAG}

                  helm upgrade --install ${SERVICE} ${HELM_CHART_PATH} \
                    -f ${HELM_VALUES_PATH} \
                    --set image.repository=${REGISTRY_HOST}/${SERVICE} \
                    --set image.tag=${IMAGE_TAG} \
                    --namespace ${KUBE_NAMESPACE} \
                    --dry-run --debug
                """
                echo "Helm lint & dry-run OK"

                sh """
                  helm upgrade --install ${SERVICE} ${HELM_CHART_PATH} \
                    -f ${HELM_VALUES_PATH} \
                    --set image.repository=${REGISTRY_HOST}/${SERVICE} \
                    --set image.tag=${IMAGE_TAG} \
                    --namespace ${KUBE_NAMESPACE} \
                    --create-namespace \
                    --atomic \
                    --timeout 5m \
                    --history-max 5
                """
                echo "Helm deploy selesai"
            }
          }
        }
      }
    }

    // ── 5. Post-Deploy Stability Check ──────────────────────
    // Masalah: helm --atomic hanya tunggu pod Running pertama kali.
    // Pod bisa crash setelah helm selesai → pipeline tetap SUCCESS.
    //
    // Solusi: setelah rollout selesai, tunggu 30 detik lalu
    // re-check restart count. Jika ada restart → pipeline FAIL
    // dan auto-rollback dijalankan di post{failure}.
    //
    // Flow:
    //   rollout status OK
    //     → tunggu 30s (beri waktu pod crash jika memang crash)
    //     → cek RESTARTS > 0 → FAIL jika iya
    //     → print logs pod yang bermasalah untuk debugging
    stage('Post-Deploy Check') {
      steps {
        container('helm') {
          script {
            withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
                // ── Step 1: Tunggu rollout selesai ──────────────
                sh """
                  echo "─── Rollout Status ───"
                  kubectl rollout status deployment/${SERVICE} \
                    -n ${KUBE_NAMESPACE} --timeout=3m
                """

                // ── Step 2: Tunggu 30 detik ─────────────────────
                // Beri waktu pod untuk crash jika memang tidak stabil.
                // CrashLoopBackOff biasanya muncul 10-30 detik setelah start.
                echo "Menunggu 30 detik untuk stability check..."
                sleep(30)

                // ── Step 3: Cek pod status & restart count ──────
                sh """
                  echo "─── Pod Status (after 30s) ───"
                  kubectl get pods -n ${KUBE_NAMESPACE} \
                    -l app.kubernetes.io/name=${SERVICE} -o wide
                """

                // Ambil restart count — jika > 0, pod crash setelah deploy
                def restartCount = sh(
                  script: """
                    kubectl get pods -n ${KUBE_NAMESPACE} \
                      -l app.kubernetes.io/name=${SERVICE} \
                      -o jsonpath='{.items[*].status.containerStatuses[*].restartCount}' \
                    | tr ' ' '\\n' | awk '{s+=\$1} END {print s+0}'
                  """,
                  returnStdout: true
                ).trim().toInteger()

                if (restartCount > 0) {
                  // ── Cetak logs pod yang crash sebelum fail ────
                  echo "⚠️  Terdeteksi ${restartCount} restart — pod tidak stabil!"
                  sh """
                    echo "─── Logs Pod (current) ───"
                    kubectl logs -n ${KUBE_NAMESPACE} \
                      -l app.kubernetes.io/name=${SERVICE} \
                      --tail=50 || true

                    echo "─── Logs Pod (previous/crashed) ───"
                    kubectl logs -n ${KUBE_NAMESPACE} \
                      -l app.kubernetes.io/name=${SERVICE} \
                      --previous --tail=50 || true

                    echo "─── Describe Pod ───"
                    kubectl describe pods -n ${KUBE_NAMESPACE} \
                      -l app.kubernetes.io/name=${SERVICE} || true

                    echo "─── Recent Events ───"
                    kubectl get events -n ${KUBE_NAMESPACE} \
                      --sort-by='.lastTimestamp' | grep ${SERVICE} | tail -15 || true
                  """
                  error "Pod restart terdeteksi (count: ${restartCount}). Deploy dianggap gagal — rollback akan dijalankan."
                }

                // ── Step 4: Final status jika stable ────────────
                sh """
                  echo "─── Final Pod Status ───"
                  kubectl get pods -n ${KUBE_NAMESPACE} \
                    -l app.kubernetes.io/name=${SERVICE} -o wide

                  echo "─── Recent Events ───"
                  kubectl get events -n ${KUBE_NAMESPACE} \
                    --sort-by='.lastTimestamp' | grep ${SERVICE} | tail -10 || true
                """
                echo "✅ Stability check OK — tidak ada restart dalam 30 detik"
            }
          }
        }
      }
    }
  }

  post {
    success {
      echo """
Deploy ${SERVICE} ke [UAT] berhasil!
   Image tag : ${IMAGE_TAG}
   Namespace : ${KUBE_NAMESPACE}
      """
    }
    failure {
      container('helm') {
        script {
          echo "Deploy gagal, mencoba rollback..."
          withCredentials([file(credentialsId: env.KUBECONFIG_CRED_ID, variable: 'KUBECONFIG')]) {
              sh "helm rollback ${SERVICE} 0 -n ${KUBE_NAMESPACE} || true"
          }
        }
      }
    }
    cleanup {
      sh 'rm -rf service-src || true'
    }
  }
}
